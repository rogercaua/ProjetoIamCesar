@page
@model DocumentPortalIam.Front.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Usuarios";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Governanca</p>
        <h1>Usuarios do LDAP demo</h1>
        <p class="lead">Altere o papel no diretorio centralizado e faca novo login para ver as permissoes mudarem.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<section class="panel">
    <h2>Contas e papeis</h2>
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>E-mail</th>
                    <th>Papel atual</th>
                    <th>Alterar papel</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@user.UserName</div>
                            <div class="text-muted small">@user.DisplayName</div>
                        </td>
                        <td>@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="status-pill">@role</span>
                            }
                        </td>
                        <td>
                            <form method="post" asp-page-handler="Role" class="row g-2">
                                <input type="hidden" name="userName" value="@user.UserName" />
                                <div class="col">
                                    <select class="form-select form-select-sm" name="role">
                                        @foreach (var role in Model.Roles)
                                        {
                                            <option value="@role.Name" selected="@(user.Roles.Contains(role.Name))">@role.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button class="btn btn-outline-primary btn-sm" type="submit">Salvar</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
