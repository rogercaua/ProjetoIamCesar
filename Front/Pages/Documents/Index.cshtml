@page
@model DocumentPortalIam.Front.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Documentos";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Repositorio</p>
        <h1>Documentos</h1>
        <p class="lead">Arquivos visiveis conforme o papel do usuario autenticado.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (Model.CanUpload)
{
    <section class="panel">
        <h2>Novo upload</h2>
        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" class="row gy-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label" asp-for="Upload">Arquivo</label>
                <input class="form-control" asp-for="Upload" type="file" />
            </div>
            <div class="col-md-3">
                <label class="form-label" asp-for="Sensitivity">Classificacao</label>
                <select class="form-select" asp-for="Sensitivity">
                    <option>Publico interno</option>
                    <option>Interno</option>
                    <option>Restrito</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100" type="submit">Enviar</button>
            </div>
        </form>
    </section>
}

<section class="panel">
    <h2>Acervo</h2>
    @if (!Model.Documents.Any())
    {
        <p class="text-muted mb-0">Nenhum documento visivel para este usuario.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Arquivo</th>
                        <th>Dono</th>
                        <th>Classificacao</th>
                        <th>Enviado em</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Documents)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Record.OriginalFileName</td>
                            <td>@item.Record.OwnerUserName</td>
                            <td><span class="status-pill">@item.Record.Sensitivity</span></td>
                            <td>@item.Record.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="action-row justify-content-end">
                                    @if (item.CanDownload)
                                    {
                                        <a class="btn btn-outline-primary btn-sm" asp-page-handler="Download" asp-route-id="@item.Record.Id">Baixar</a>
                                    }
                                    @if (item.CanExportOidc)
                                    {
                                        <a class="btn btn-outline-secondary btn-sm" asp-page="/Exports/Oidc" asp-route-documentId="@item.Record.Id">Exportar OIDC</a>
                                    }
                                    @if (item.CanDelete)
                                    {
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Record.Id">
                                            <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
